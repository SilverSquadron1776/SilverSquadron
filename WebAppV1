<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NSWDG Silver Squadron</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #0a0a0a;
      --silver: #9ca3a8;
      --silver-bright: #c8d0d5;
      --white: #eaeaea;
      --accent: #7a8a92;
      --rule: rgba(156,163,168,0.18);
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      line-height: 1.6;
      overflow-x: hidden;
    }
    .banner {
      width: 100%;
      position: relative;
      overflow: hidden;
      max-height: 420px;
    }
    .banner img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
      filter: brightness(0.72) contrast(1.1);
    }
    .banner::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(10,10,10,0.15) 0%, rgba(10,10,10,0.85) 100%);
    }
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,10,0.94);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--rule);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 2.5rem;
      height: 60px;}
    .nav-logo { display: flex; align-items: center; gap: 0.75rem; }
    .nav-logo img { height: 38px; width: 38px; object-fit: contain; }
    .nav-wordmark {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.25rem;
      letter-spacing: 0.12em;
      color: var(--silver-bright);
    }
    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 5rem 1.5rem 4rem;
      text-align: center;
    }
    .hero-logo {
      width: 130px;
      height: 130px;
      object-fit: contain;
      margin-bottom: 1.75rem;
      filter: drop-shadow(0 0 24px rgba(156,163,168,0.22));
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.6rem;
    }
    .hero h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.2rem, 8vw, 6.5rem);
