<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NSWDG Silver Squadron</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;600;700&family=Barlow:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --black: #0a0a0a;
      --silver: #9ca3a8;
      --silver-bright: #c8d0d5;
      --white: #eaeaea;
      --accent: #7a8a92;
      --rule: rgba(156,163,168,0.18);
    }
    html { scroll-behavior: smooth; }
    body {
      background: var(--black);
      color: var(--white);
      font-family: 'Barlow', sans-serif;
      font-weight: 300;
      line-height: 1.6;
      overflow-x: hidden;
    }
    .banner {
      width: 100%;
      position: relative;
      overflow: hidden;
      max-height: 420px;
    }
    .banner img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      display: block;
      filter: brightness(0.72) contrast(1.1);
    }
    .banner::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(10,10,10,0.15) 0%, rgba(10,10,10,0.85) 100%);
    }
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10,10,10,0.94);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--rule);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 2.5rem;
      height: 60px;
    }
    .nav-logo { display: flex; align-items: center; gap: 0.75rem; }
    .nav-logo img { height: 38px; width: 38px; object-fit: contain; }
    .nav-wordmark {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.25rem;
      letter-spacing: 0.12em;
      color: var(--silver-bright);
    }
    .hero {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 5rem 1.5rem 4rem;
      text-align: center;
    }
    .hero-logo {
      width: 130px;
      height: 130px;
      object-fit: contain;
      margin-bottom: 1.75rem;
      filter: drop-shadow(0 0 24px rgba(156,163,168,0.22));
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .eyebrow {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.6rem;
    }
    .hero h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: clamp(3.2rem, 8vw, 6.5rem);
      letter-spacing: 0.08em;
      line-height: 0.95;
      color: var(--white);
      margin-bottom: 0.5rem;
    }
    .hero h1 span { color: var(--silver); display: block; }
    .rule-line {
      width: 60px; height: 1px;
      background: var(--silver);
      margin: 1.5rem auto;
      opacity: 0.5;
    }
    .hero-sub {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.85rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .collage-section {
      padding: 4rem 2rem 5rem;
      max-width: 1200px;
      margin: 0 auto;
    }
    .section-label {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .section-label::after {
      content: ''; flex: 1;
      height: 1px; background: var(--rule);
    }
    .collage {
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      grid-template-rows: auto auto;
      gap: 6px;
    }
    .collage-item { overflow: hidden; position: relative; }
    .collage-item:first-child { grid-row: 1 / 3; }
    .collage-item img {
      width: 100%; height: 100%;
      object-fit: cover; display: block;
      transition: transform 0.5s ease, filter 0.5s ease;
      filter: brightness(0.85) saturate(0.8);
    }
    .collage-item:first-child img { min-height: 480px; }
    .collage-item:not(:first-child) img { min-height: 235px; }
    .collage-item:hover img { transform: scale(1.04); filter: brightness(1) saturate(1); }
    .collage-caption {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      padding: 1rem 1.25rem 0.85rem;
      background: linear-gradient(to top, rgba(10,10,10,0.8) 0%, transparent 100%);
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--silver);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .collage-item:hover .collage-caption { opacity: 1; }
    footer {
      border-top: 1px solid var(--rule);
      padding: 2rem 2.5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }
    .footer-logo { display: flex; align-items: center; gap: 0.65rem; }
    .footer-logo img { height: 28px; object-fit: contain; filter: brightness(0.6); }
    .footer-text {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      opacity: 0.6;
    }
    .classification {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 0.62rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent);
      opacity: 0.35;
    }
    @media (max-width: 700px) {
      .collage { grid-template-columns: 1fr; }
      .collage-item:first-child { grid-row: auto; }
      .collage-item:first-child img { min-height: 280px; }
      .collage-item:not(:first-child) img { min-height: 200px; }
      footer { flex-direction: column; align-items: flex-start; }
    }
    @media (prefers-reduced-motion: reduce) {
      .hero-logo { animation: none; }
      .collage-item img { transition: none; }
    }
  </style>
</head>
